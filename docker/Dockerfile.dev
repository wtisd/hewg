FROM mcr.microsoft.com/devcontainers/typescript-node:1-20-bookworm

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
# ENV UV_HOME="/opt/uv"
# ENV PATH="$UV_HOME/bin:$PATH"
# ENV UV_COMPILE_BYTECODE=1
# ENV UV_LINK_MODE=copy
# ENV UV_CACHE_DIR=/home/vscode/.cache/uv
# ENV POETRY_VIRTUALENVS_IN_PROJECT=true

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl vim git ssh sudo bash \
    ripgrep \
    ca-certificates \
    wget \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Playwright system dependencies
# This installs all browser dependencies without the browsers themselves
RUN npx playwright install-deps chromium

# Create a non-root user 'vscode'
# RUN useradd -m vscode \
#     && groupadd docker \
#     && usermod -aG docker vscode

# RUN echo "vscode ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Switch to the non-root user
# USER vscode

# Copy project files (optional, can be mounted by docker-compose)
# COPY --chown=vscode:vscode . /workspace
SHELL ["/bin/bash", "-c"]

# Keep the container running
CMD ["sleep", "infinity"]
