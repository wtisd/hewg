{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "name": "@erdtree/hewg",
  "version": "0.1.0",
  "exports": {
    ".": "./src/mod.ts",
    "./cli": "./src/cli/mod.ts"
  },
  "tasks": {
    "dev": "deno run --watch src/main.ts",
    "start": "deno run src/main.ts",
    "test": "deno test --allow-read --allow-env",
    "test:watch": "deno test --allow-read --allow-env --watch",
    "test:coverage": "deno test --allow-read --allow-env --coverage=coverage/",
    "coverage": "deno coverage coverage/ --lcov > coverage/lcov.info",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "compile": "deno compile --allow-read --allow-env --allow-net --output dist/hewg src/main.ts",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task test"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/fmt": "jsr:@std/fmt@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": [
        "camelcase",
        "no-sync-fn-in-async-fn",
        "single-var-declarator"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "test": {
    "include": ["tests/"]
  }
}
